{
  "name": "@contexa/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Contexa CLI (`ctx` bin): install/doctor/mcp/guide/import/remember/recall/memory/push/sync. Placeholder name until P13 naming lands.",
  "bin": {
    "ctx": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@contexa/core": "workspace:*",
    "@contexa/guide": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.3",
    "typescript": "rc",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.16"
  }
}
