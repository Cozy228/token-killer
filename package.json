{
  "name": "token-killer",
  "version": "0.3.1",
  "description": "Token-saving command proxy.",
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "bin": {
    "tk": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsdown",
    "prepack": "tsdown",
    "test": "vitest --config vitest.config.ts",
    "test:product": "vitest run --config vitest.config.ts",
    "test:smoke": "bash tests/smoke/smoke.sh",
    "test:windows-dogfood": "pwsh -NoProfile -File scripts/windows-dogfood.ps1",
    "test:ci": "pnpm test:product && bash tests/smoke/smoke.sh",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "oxfmt",
      "oxlint --fix --vitest-plugin"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "rc",
    "vitest": "^4.1.9"
  }
}
