# Deploy environment variables for server/scripts/deploy.sh
# Copy this file to deploy.env and fill in the values.
#
#   cp deploy.env.example deploy.env
#   source deploy.env && ./deploy.sh
#
# deploy.env is gitignored — never commit real credentials or ARNs.

# ---- Required ----

# AWS authentication (pick one)
AWS_PROFILE=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

AWS_REGION=us-east-1

# ACM certificate ARN for the internal ALB HTTPS listener (required when INGRESS=alb)
# Leave empty if using INGRESS=apigw
CERT_ARN=

# ---- Optional overrides (auto-discovered otherwise) ----

# Stack name prefix
NAME_PREFIX=tk-telemetry

# VPC to deploy into (default: the account's default VPC)
VPC_ID=

# Subnets (default: one private subnet per AZ in the VPC)
# SUBNET_IDS="subnet-aaa subnet-bbb"

# Who may reach the private API (default: the VPC CIDR)
# CLIENT_CIDR=10.0.0.0/8

# Front door: "alb" (internal ALB) or "apigw" (private API Gateway)
INGRESS=alb

# ALB config (only used when INGRESS=alb)
LISTENER_PORT=443
ALB_MIN_FREE_IPS=8

# Create secretsmanager + logs VPC endpoints (set false if NAT/shared endpoints exist)
CREATE_INTERFACE_ENDPOINTS=true

# RDS config
DB_INSTANCE_CLASS=db.t4g.micro
DB_NAME=telemetry
DB_USERNAME=tk_ingest

# Docker image tag (default: git short sha)
# IMAGE_TAG=
